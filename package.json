{
  "name": "linkedin-job-tracker",
  "version": "1.0.0",
  "description": "Daily LinkedIn job match dashboard (guest scraping, manual apply)",
  "main": "scraper/run.js",
  "scripts": {
    "scrape": "node scraper/run.js",
    "server": "node server.js",
    "stop": "pkill -f 'node server.js'; pkill -f vite; true",
    "dev": "concurrently \"node server.js\" \"npm run dev --prefix dashboard\"",
    "restart": "npm run stop && npm run dev"
  },
  "dependencies": {
    "express": "^4.19.2",
    "pdf-parse": "^1.1.1",
    "puppeteer": "^22.15.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
